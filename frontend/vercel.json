{
  "rewrites": [
    {
      "source": "/((?!assets/|sw.js|workbox-|registerSW.js|manifest.webmanifest|.*\\.(?:js|css|png|svg|ico|webmanifest|woff2)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
