# Backend base URLs. In production these point at the Railway domain.
VITE_API_URL=http://localhost:8137
VITE_WS_URL=ws://localhost:8137/ws/threats

# Telegram Login Widget — the bot's username (without @). When set, the
# Telegram sign-in button renders. The bot's domain must be bound in
# @BotFather (/setdomain) to the page origin, or the widget refuses to load.
VITE_TELEGRAM_LOGIN_BOT=klr_admin_bot
